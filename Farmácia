        "import os\n",
        "\n",
        "class Farmacia:\n",
        "    def __init__(self):\n",
        "        # Banco de dados inicial (Mock Data)\n",
        "        self.medicamentos = {\n",
        "            i: {\"nome\": f\"Medicamento {i}\", \"preco\": round(10.5 * i, 2), \"estoque\": 50}\n",
        "            for i in range(1, 51)\n",
        "        }\n",
        "        self.proximo_id = 51\n",
        "\n",
        "    def limpar_tela(self):\n",
        "        # Limpa o console dependendo do SO (Windows ou Unix)\n",
        "        os.system('cls' if os.name == 'nt' else 'clear')\n",
        "\n",
        "    def menu(self):\n",
        "        while True:\n",
        "            print(\"\\n\" + \"=\"*30)\n",
        "            print(\"  SISTEMA DE GESTÃO FARMACÊUTICA\")\n",
        "            print(\"=\"*30)\n",
        "            print(\"1. Listar Medicamentos\")\n",
        "            print(\"2. Cadastrar Novo\")\n",
        "            print(\"3. Atualizar Produto\")\n",
        "            print(\"4. Registrar Saída (Venda)\")\n",
        "            print(\"5. Excluir Registro\")\n",
        "            print(\"0. Sair\")\n",
        "\n",
        "            opcao = input(\"\\nSelecione uma opção: \")\n",
        "\n",
        "            try:\n",
        "                if opcao == '1': self.listar()\n",
        "                elif opcao == '2': self.cadastrar()\n",
        "                elif opcao == '3': self.atualizar()\n",
        "                elif opcao == '4': self.registrar_saida()\n",
        "                elif opcao == '5': self.excluir()\n",
        "                elif opcao == '0':\n",
        "                    print(\"Encerrando sistema...\")\n",
        "                    break\n",
        "                else:\n",
        "                    print(\"\\n⚠️ Opção inválida!\")\n",
        "            except ValueError:\n",
        "                print(\"\\n❌ Erro: Digite valores numéricos corretos para preço/estoque.\")\n",
        "            except Exception as e:\n",
        "                print(f\"\\n❌ Ocorreu um erro inesperado: {e}\")\n",
        "\n",
        "    def listar(self):\n",
        "        self.limpar_tela()\n",
        "        print(f\"\\n{'ID':<5} | {'Nome':<25} | {'Preço':<12} | {'Estoque':<8}\")\n",
        "        print(\"-\" * 60)\n",
        "        for mid, dados in self.medicamentos.items():\n",
        "            print(f\"{mid:<5} | {dados['nome']:<25} | R${dados['preco']:>9.2f} | {dados['estoque']:>8}\")\n",
        "        input(\"\\nPressione Enter para voltar ao menu...\")\n",
        "\n",
        "    def cadastrar(self):\n",
        "        nome = input(\"Nome do medicamento: \").strip()\n",
        "        if not nome: raise ValueError(\"O nome não pode ser vazio.\")\n",
        "\n",
        "        preco = float(input(\"Preço de venda: \"))\n",
        "        estoque = int(input(\"Quantidade em estoque: \"))\n",
        "\n",
        "        self.medicamentos[self.proximo_id] = {\"nome\": nome, \"preco\": preco, \"estoque\": estoque}\n",
        "        print(f\"\\n✅ {nome} cadastrado com sucesso! ID: {self.proximo_id}\")\n",
        "        self.proximo_id += 1\n",
        "\n",
        "    def atualizar(self):\n",
        "        mid = int(input(\"Digite o ID do medicamento para editar: \"))\n",
        "        if mid in self.medicamentos:\n",
        "            print(f\"Editando: {self.medicamentos[mid]['nome']}\")\n",
        "            self.medicamentos[mid]['preco'] = float(input(\"Novo Preço: \"))\n",
        "            self.medicamentos[mid]['estoque'] = int(input(\"Novo Estoque: \"))\n",
        "            print(\"✅ Atualização concluída!\")\n",
        "        else:\n",
        "            print(\"⚠️ ID não encontrado.\")\n",
        "\n",
        "    def registrar_saida(self):\n",
        "        mid = int(input(\"ID do medicamento para venda/saída: \"))\n",
        "        if mid in self.medicamentos:\n",
        "            qtd = int(input(f\"Quantidade (Disponível: {self.medicamentos[mid]['estoque']}): \"))\n",
        "            if 0 < qtd <= self.medicamentos[mid]['estoque']:\n",
        "                self.medicamentos[mid]['estoque'] -= qtd\n",
        "                print(f\"✅ Venda realizada! Novo estoque: {self.medicamentos[mid]['estoque']}\")\n",
        "            else:\n",
        "                print(\"⚠️ Quantidade inválida ou estoque insuficiente.\")\n",
        "        else:\n",
        "            print(\"⚠️ ID não encontrado.\")\n",
        "\n",
        "    def excluir(self):\n",
        "        mid = int(input(\"ID do medicamento para exclusão: \"))\n",
        "        if mid in self.medicamentos:\n",
        "            confirmar = input(f\"Tem certeza que deseja excluir {self.medicamentos[mid]['nome']}? (s/n): \")\n",
        "            if confirmar.lower() == 's':\n",
        "                del self.medicamentos[mid]\n",
        "                print(\"🗑️ Registro removido.\")\n",
        "        else:\n",
        "            print(\"⚠️ ID não encontrado.\")\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    app = Farmacia()\n",
        "    app.menu()"
      ]
